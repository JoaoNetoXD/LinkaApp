# Frontend / Supabase client
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica

# Backend / Supabase privileged operations
# Required in production for Mercado Pago webhooks to issue coupons without a logged-in browser session.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Mercado Pago
MP_ACCESS_TOKEN=APP_USR-seu-access-token-de-producao
MP_CLIENT_ID=seu-app-id-mercado-pago
MP_CLIENT_SECRET=seu-client-secret-mercado-pago

# Public URLs
# In Netlify production, use the final site URL, for example:
# FRONTEND_URL=https://linka.netlify.app
# WEBHOOK_URL and MP_REDIRECT_URI are derived automatically from FRONTEND_URL.
FRONTEND_URL=http://localhost:5173
WEBHOOK_URL=http://localhost:3000/api/webhook
MP_REDIRECT_URI=http://localhost:3000/api/mercadopago/oauth/callback

# Frontend API URL
# Keep empty in Netlify production so the app calls /api on the same domain.
VITE_API_URL=/api

# Optional
PORT=3000
